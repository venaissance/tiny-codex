{
  "name": "tiny-codex",
  "version": "1.2.3",
  "description": "Lightweight Electron-based AI coding assistant",
  "main": "dist/main/main/index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:renderer": "vite src/renderer --port 5173",
    "dev:main": "tsc --project tsconfig.main.json --watch",
    "build": "tsc --project tsconfig.main.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack": "pnpm run build && electron-builder --dir",
    "release": "pnpm run build && electron-builder"
  },
  "keywords": [],
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^3.23.0",
    "sql.js": "^1.14.1",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/node": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.8.9",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
